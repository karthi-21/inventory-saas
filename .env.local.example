# ============================================
# OmniBIZ - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# For local development: cp .env.local.example .env.local

# ============================================
# SUPABASE (Required for auth + database)
# ============================================
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
# Public URL of your Supabase project
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
# Public anon key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.placeholder_anon_key
# Service role key — keep this secret, never expose client-side
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.placeholder_service_role_key

# ============================================
# RAZORPAY (Required for payments - Day 2+)
# ============================================
# Get test keys from: https://dashboard.razorpay.com/app/keys
# Use rzp_test_ prefix for test mode
# Your Razorpay API key ID
RAZORPAY_KEY_ID=rzp_test_your_key_id
# Your Razorpay API key secret
RAZORPAY_KEY_SECRET=your_key_secret
# Webhook secret for verifying Razorpay webhook signatures
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ============================================
# EMAIL (Required for notifications - Day 12+)
# ============================================
# Using Resend - https://resend.com
# API key for sending transactional emails via Resend
RESEND_API_KEY=re_your_resend_api_key

# ============================================
# WHATSAPP (Optional - Day 12+)
# ============================================
# WhatsApp Business API token for sending notifications
WHATSAPP_BUSINESS_TOKEN=your_whatsapp_business_token

# ============================================
# APP CONFIG
# ============================================
# Public URL where the app is served (used for OAuth redirects, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Display name of the application
NEXT_PUBLIC_APP_NAME=OmniBIZ

# ============================================
# AUTH PROVIDERS (Enable/disable auth methods)
# Set to 'true' to enable, 'false' to disable
# ============================================
# Enable email + password authentication
NEXT_PUBLIC_ENABLE_EMAIL_AUTH=true
# Enable Google OAuth authentication
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=false
# Enable phone (OTP) authentication
NEXT_PUBLIC_ENABLE_PHONE_AUTH=false

# ============================================
# DATABASE (For Prisma migrations)
# ============================================
# Get this from Supabase dashboard > Settings > Database
# Pooled connection string (used by the app at runtime via Prisma)
# Format: postgresql://postgres.[PROJECT_ID]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=postgresql://postgres:your_password@db.your-project-id.supabase.co:5432/postgres
# Direct connection to the database (used for Prisma migrations)
# Format: postgresql://postgres.[PROJECT_ID]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
DIRECT_URL=postgresql://postgres:your_password@db.your-project-id.supabase.co:5432/postgres
