# ============================================
# Ezvento - Environment Variables
# ============================================

# ============================================
# SUPABASE (Required for auth + database)
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ============================================
# DODO PAYMENTS (Required for SaaS subscriptions)
# Get from: https://dashboard.dodopayments.com
# Dashboard → Settings → API Keys (for API Key & Webhook Secret)
# Dashboard → Products (for Plan IDs)
# ============================================
DODO_API_KEY=dodo_test_your_key_here
DODO_WEBHOOK_SECRET=whsec_your_webhook_secret_here
DODO_BASE_URL=https://api.sandbox.dodopayments.com
DODO_LAUNCH_PLAN_ID=prod_your_launch_plan_id
DODO_GROW_PLAN_ID=prod_your_grow_plan_id
NEXT_PUBLIC_DODO_PUBLIC_KEY=dodo_pub_your_public_key_here

# ============================================
# PHONEPE (Required for POS payments)
# Get from: https://developer.phonepe.com
# Dashboard → API Keys / Credentials (for Client ID, Client Secret, Merchant ID)
# ============================================
# v2 auth (preferred — what your dashboard shows as "Client ID" and "Client Secret")
PHONEPE_CLIENT_ID=your_client_id_here
PHONEPE_CLIENT_SECRET=your_client_secret_here
PHONEPE_MERCHANT_ID=MERCHANTUATxxxxx
PHONEPE_API_URL=https://api-preprod.phonepe.com/apis/pg-sandbox
PHONEPE_CALLBACK_URL=https://yourdomain.com/api/payments/pos/webhook
PHONEPE_REDIRECT_URL=https://yourdomain.com/dashboard/billing

# PhonePe v1 (legacy — only if your dashboard shows "Salt Key" instead)
# PHONEPE_SALT_KEY=your_salt_key_here
# PHONEPE_SALT_INDEX=1

# ============================================
# EMAIL (Required for notifications)
# Get from: https://resend.com → API Keys
# ============================================
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=Ezvento <billing@ezvento.karth-21.com>
RESEND_REPLY_TO=support@ezvento.karth-21.com

# ============================================
# CRON (for Vercel scheduled jobs — payment reminders)
# ============================================
CRON_SECRET=your_random_cron_secret_here

# ============================================
# GST / E-INVOICING (Optional)
# ============================================
GSP_BASE_URL=https://einv-apisandbox.nic.in
GSP_CLIENT_ID=your_gsp_client_id
GSP_CLIENT_SECRET=your_gsp_client_secret
GSTN_GSTIN=your_gstin_here
GSTN_USERNAME=your_gstn_username
GSTN_PASSWORD=your_gstn_password

# ============================================
# SENTRY (Optional - error monitoring)
# ============================================
NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# ============================================
# APP CONFIG
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3003
NEXT_PUBLIC_APP_NAME=Ezvento

# ============================================
# AUTH PROVIDERS
# ============================================
NEXT_PUBLIC_ENABLE_EMAIL_AUTH=true
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=false
NEXT_PUBLIC_ENABLE_PHONE_AUTH=false

# ============================================
# DATABASE (For Prisma migrations)
# ============================================
DATABASE_URL=postgresql://postgres:your_password@db.your-project-id.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:your_password@db.your-project-id.supabase.co:5432/postgres
